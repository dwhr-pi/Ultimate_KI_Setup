# General
COMPOSE_PROJECT_NAME=ultimate-ki
TZ=Europe/Berlin
DOMAIN=botsoft.uk
PUBLIC_BASE_URL=https://botsoft.uk

# Reverse proxy
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
ACME_EMAIL=admin@botsoft.uk

# OpenClaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_CONFIG_DIR=./openclaw
OPENCLAW_WORKSPACE_DIR=./data/workspace
OPENCLAW_GATEWAY_TOKEN=change-this-to-a-long-random-token
OPENCLAW_ALLOWED_ORIGIN=https://botsoft.uk
OPENCLAW_AGENT_TIMEZONE=Europe/Berlin
OPENCLAW_PRIMARY_MODEL=google/gemini-2.5-flash
OPENCLAW_FALLBACK_MODEL=ollama/llama3.2:1b
OPENCLAW_LOG_LEVEL=info

# Gemini / Google
GEMINI_API_KEY=replace-with-your-gemini-api-key
GOOGLE_API_KEY=

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_API_KEY=ollama-local
OLLAMA_MODEL=llama3.2:1b
OLLAMA_KEEP_ALIVE=24h
OLLAMA_ORIGINS=https://botsoft.uk,https://www.botsoft.uk
